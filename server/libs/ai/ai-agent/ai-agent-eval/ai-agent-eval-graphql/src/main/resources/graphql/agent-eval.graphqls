extend type Query {
    agentJudges(workflowId: String!, workflowNodeName: String!): [AgentJudge!]!
    agentEvalTests(workflowId: String!, workflowNodeName: String!): [AgentEvalTest!]!
    agentEvalTest(id: ID!): AgentEvalTest
    agentEvalRuns(agentEvalTestId: ID!, limit: Int, offset: Int): [AgentEvalRun!]!
    agentEvalRun(id: ID!): AgentEvalRun
    agentEvalResult(id: ID!): AgentEvalResult
    agentEvalResultTranscript(id: ID!): String
}

extend type Mutation {
    createAgentJudge(workflowId: String!, workflowNodeName: String!, name: String!, type: AgentJudgeType!, configuration: Map!): AgentJudge!
    updateAgentJudge(id: ID!, name: String, configuration: Map): AgentJudge!
    deleteAgentJudge(id: ID!): Boolean!

    createAgentEvalTest(workflowId: String!, workflowNodeName: String!, name: String!, description: String): AgentEvalTest!
    updateAgentEvalTest(id: ID!, name: String, description: String): AgentEvalTest!
    deleteAgentEvalTest(id: ID!): Boolean!

    createAgentEvalScenario(agentEvalTestId: ID!, name: String!, type: AgentScenarioType!, userMessage: String, expectedOutput: String, personaPrompt: String, maxTurns: Int): AgentEvalScenario!
    updateAgentEvalScenario(id: ID!, name: String, userMessage: String, expectedOutput: String, personaPrompt: String, maxTurns: Int): AgentEvalScenario!
    deleteAgentEvalScenario(id: ID!): Boolean!

    createAgentScenarioJudge(agentEvalScenarioId: ID!, name: String!, type: AgentJudgeType!, configuration: Map!): AgentScenarioJudge!
    updateAgentScenarioJudge(id: ID!, name: String, configuration: Map): AgentScenarioJudge!
    deleteAgentScenarioJudge(id: ID!): Boolean!

    startAgentEvalRun(agentEvalTestId: ID!, name: String!, environmentId: ID!): AgentEvalRun!
    cancelAgentEvalRun(id: ID!): AgentEvalRun!
}

type AgentJudge {
    id: ID!
    name: String!
    type: AgentJudgeType!
    configuration: Map!
    createdDate: Long
    lastModifiedDate: Long
}

type AgentEvalTest {
    id: ID!
    name: String!
    description: String
    scenarios: [AgentEvalScenario!]!
    createdDate: Long
    lastModifiedDate: Long
}

type AgentEvalScenario {
    id: ID!
    name: String!
    type: AgentScenarioType!
    userMessage: String
    expectedOutput: String
    personaPrompt: String
    maxTurns: Int
    judges: [AgentScenarioJudge!]!
    createdDate: Long
    lastModifiedDate: Long
}

type AgentScenarioJudge {
    id: ID!
    name: String!
    type: AgentJudgeType!
    configuration: Map!
    createdDate: Long
    lastModifiedDate: Long
}

type AgentEvalRun {
    id: ID!
    name: String!
    status: AgentEvalRunStatus!
    averageScore: Float
    totalScenarios: Int!
    completedScenarios: Int!
    startedDate: Long
    completedDate: Long
    results: [AgentEvalResult!]!
    createdDate: Long
}

type AgentEvalResult {
    id: ID!
    scenario: AgentEvalScenario!
    status: AgentEvalResultStatus!
    score: Float
    errorMessage: String
    transcriptFile: String
    verdicts: [AgentJudgeVerdict!]!
    createdDate: Long
}

type AgentJudgeVerdict {
    id: ID!
    judgeName: String!
    judgeType: AgentJudgeType!
    judgeScope: AgentJudgeScope!
    passed: Boolean!
    score: Float!
    explanation: String!
}

enum AgentJudgeType {
    LLM_RULE
    CONTAINS_TEXT
    REGEX_MATCH
    RESPONSE_LENGTH
    JSON_SCHEMA
    SIMILARITY
}

enum AgentJudgeScope {
    AGENT
    SCENARIO
}

enum AgentScenarioType {
    SINGLE_TURN
    MULTI_TURN
}

enum AgentEvalRunStatus {
    PENDING
    RUNNING
    COMPLETED
    FAILED
}

enum AgentEvalResultStatus {
    PENDING
    RUNNING
    COMPLETED
    FAILED
}
