<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260425120000-1" author="Ivica Cardic">
        <addColumn tableName="approval_task">
            <column name="status" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="priority" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="assignee_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint
            baseColumnNames="assignee_id"
            baseTableName="approval_task"
            constraintName="fk_approval_task_assignee"
            referencedColumnNames="id"
            referencedTableName="user"/>

        <createIndex indexName="idx_approval_task_assignee_id" tableName="approval_task">
            <column name="assignee_id"/>
        </createIndex>

        <createIndex indexName="idx_approval_task_status" tableName="approval_task">
            <column name="status"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
