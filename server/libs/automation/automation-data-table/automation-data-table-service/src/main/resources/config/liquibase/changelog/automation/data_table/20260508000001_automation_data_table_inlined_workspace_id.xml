<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="20260508000001-1" author="Ivica Cardic">
        <addColumn tableName="data_table">
            <column name="workspace_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260508000001-2" author="Ivica Cardic">
        <sql>
            UPDATE data_table dt
            SET workspace_id = wdt.workspace_id
            FROM workspace_data_table wdt
            WHERE wdt.data_table_id = dt.id
        </sql>
    </changeSet>

    <changeSet id="20260508000001-3" author="Ivica Cardic">
        <addForeignKeyConstraint
            baseTableName="data_table"
            baseColumnNames="workspace_id"
            constraintName="fk_data_table_workspace"
            referencedTableName="workspace"
            referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="20260508000001-4" author="Ivica Cardic">
        <dropTable tableName="workspace_data_table"/>
    </changeSet>
</databaseChangeLog>
