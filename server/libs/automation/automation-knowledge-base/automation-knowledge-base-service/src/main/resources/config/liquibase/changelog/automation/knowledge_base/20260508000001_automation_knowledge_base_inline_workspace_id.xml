<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="20260508000001-1" author="Ivica Cardic">
        <addColumn tableName="knowledge_base">
            <column name="workspace_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260508000001-2" author="Ivica Cardic">
        <sql>
            UPDATE knowledge_base
            SET workspace_id = (
                SELECT workspace_id
                FROM workspace_knowledge_base
                WHERE workspace_knowledge_base.knowledge_base_id = knowledge_base.id
                LIMIT 1
            )
        </sql>
    </changeSet>

    <changeSet id="20260508000001-3" author="Ivica Cardic">
        <addNotNullConstraint tableName="knowledge_base" columnName="workspace_id" columnDataType="BIGINT"/>

        <addForeignKeyConstraint
            baseTableName="knowledge_base"
            baseColumnNames="workspace_id"
            constraintName="fk_knowledge_base_workspace"
            referencedTableName="workspace"
            referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="20260508000001-4" author="Ivica Cardic">
        <dropUniqueConstraint tableName="knowledge_base" constraintName="uk_knowledge_base_name"/>

        <addUniqueConstraint
            tableName="knowledge_base"
            columnNames="workspace_id,name"
            constraintName="uk_knowledge_base_workspace_name"/>
    </changeSet>

    <changeSet id="20260508000001-5" author="Ivica Cardic">
        <dropTable tableName="workspace_knowledge_base"/>
    </changeSet>
</databaseChangeLog>
