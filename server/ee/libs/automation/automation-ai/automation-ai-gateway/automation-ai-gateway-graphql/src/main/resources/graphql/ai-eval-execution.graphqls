extend type Query {
    aiEvalExecutions(evalRuleId: ID!): [AiEvalExecution]
    aiEvalExecutionsByTrace(traceId: ID!): [AiEvalExecution]
}

type AiEvalExecution {
    createdDate: Long
    errorMessage: String
    evalRuleId: ID!
    id: ID!
    scoreId: ID
    status: AiEvalExecutionStatus!
    traceId: ID!
}

enum AiEvalExecutionStatus {
    COMPLETED
    ERROR
    PENDING
}
