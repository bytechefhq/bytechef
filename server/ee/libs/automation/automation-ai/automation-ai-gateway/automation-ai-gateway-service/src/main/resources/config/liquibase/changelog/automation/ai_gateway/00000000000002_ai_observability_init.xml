        <createIndex tableName="ai_observability_session" indexName="idx_ai_obs_session_user">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="ai_observability_session" indexName="idx_ai_obs_session_workspace_user">
            <column name="workspace_id"/>
            <column name="user_id"/>
        </createIndex>

        <createTable tableName="ai_observability_trace">
