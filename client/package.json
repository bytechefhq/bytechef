    "scripts": {
        "dev": "vite",
        "codegen": "graphql-codegen --config codegen.ts",
        "check:node": "node scripts/check-node-version.mjs",
        "build": "npm run check:node && tsc && vite build",
        "build:cloud": "npm run check:node && tsc && vite build --mode cloud",
        "serve": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "test:coverage": "vitest run --coverage",
        "playwright": "playwright test",
        "playwright:ui": "playwright test --ui",
        "playwright:headed": "playwright test --headed",
        "playwright:debug": "playwright test --debug",
        "test:all": "npm run test && npm run playwright",
        "lingui:extract": "lingui extract",
        "lingui:compile": "lingui compile --typescript",
        "lint": "eslint src --max-warnings=0",
        "typecheck": "tsc --project tsconfig.json --noEmit",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md}\" && eslint src --max-warnings=0 --fix",
        "check": "prettier --check \"**/*.{js,jsx,ts,tsx,md}\" && eslint src --max-warnings=0 && tsc --project tsconfig.json --noEmit && vitest run --coverage",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
