{
    "name": "@bytechef/embedded-react",
    "version": "0.1.0",
    "description": "ByteChef Embedded React SDK.",
    "type": "module",
    "scripts": {
        "build": "tsc && vite build",
        "lint": "eslint 'src/**/*.{ts,tsx}'",
        "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
        "format": "prettier --check .",
        "format:fix": "prettier --write \"**/*.{js,jsx,ts,tsx,md}\" && eslint src --max-warnings=0 --fix",
        "stylelint": "stylelint **/*.css",
        "stylelint:fix": "stylelint **/*.css --fix",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:watch": "vitest --watch",
        "coverage": "vitest run --coverage",
        "watch": "tsc && vite build --watch",
        "publish:local": "npm publish --registry http://localhost:4873",
        "link:local": "npm link",
        "unlink:local": "npm unlink -g @bytechef/embedded-react"
    },
    "module": "./dist/main.js",
    "exports": "./dist/main.js",
    "files": [
        "dist"
    ],
    "types": "./dist/main.d.ts",
    "peerDependencies": {
        "react": "^19.2.3",
        "react-dom": "^19.2.3"
    },
    "author": "Kresimir Coko <kresimir.coko@bytechef.io>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bytechefhq/bytechef.git",
        "directory": "sdks/frontend/embedded/library/react"
    },
    "keywords": [
        "bytechef",
        "embedded",
        "workflow",
        "automation",
        "react",
        "sdk"
    ],
    "devDependencies": {
        "@chromatic-com/storybook": "5.2.1",
        "@eslint/js": "10.0.1",
        "@storybook/react": "10.4.1",
        "@storybook/react-vite": "10.4.1",
        "@tailwindcss/vite": "4.3.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "16.3.2",
        "@types/node": "25.9.1",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "6.0.2",
        "@vitest/coverage-v8": "4.1.7",
        "@vitest/ui": "4.1.7",
        "clsx": "^2.1.1",
        "eslint": "10.4.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-react-refresh": "0.5.2",
        "eslint-plugin-storybook": "10.4.1",
        "glob": "13.0.6",
        "globals": "17.6.0",
        "jsdom": "29.1.1",
        "prettier": "3.8.3",
        "storybook": "^10.4.1",
        "stylelint": "17.12.0",
        "stylelint-config-standard": "40.0.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "4.3.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "5.7.3",
        "typescript-eslint": "8.60.0",
        "vite": "^8.0.16",
        "vite-plugin-dts": "5.0.1",
        "vite-plugin-lib-inject-css": "2.2.2",
        "vitest": "4.1.7"
    },
    "main": "eslint.config.js",
    "bugs": {
        "url": "https://github.com/bytechefhq/bytechef/issues"
    },
    "homepage": "https://github.com/bytechefhq/bytechef#readme"
}
